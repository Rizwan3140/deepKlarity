# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/recipe_db

# Google Gemini API key (free tier at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (gemini-1.5-flash is free tier; gemini-1.5-pro is higher quality)
GEMINI_MODEL=gemini-1.5-flash
